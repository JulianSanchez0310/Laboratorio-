# ─────────────────────────────────────────────────────────
# Copia este archivo a .env y ajusta los valores
# cp .env.example .env
# ─────────────────────────────────────────────────────────

# Tamaños de entrada para el benchmark (separados por coma)
BENCHMARK_SIZES=10,100,10000,1000000,100000000

# Número de repeticiones para calcular promedios
BENCHMARK_REPETITIONS=100

# Nivel de log: INFO | WARNING | FINE | SEVERE
LOG_LEVEL=INFO
